# Frontend Environment Variables Template
# Copy this file to .env and update the values

# Vite Dev Server Proxy Target (for development mode only)
# Development (local): http://localhost:6789
# Docker dev: http://backend:6789
# Leave empty to use default (localhost:6789)
VITE_PROXY_TARGET=

# API Base URL (for production/Docker deployment)
# Development: leave empty or set to http://localhost:6789
# Production/Docker: set to your domain or backend service name
VITE_API_BASE_URL=

# GitHub repository URL
VITE_GITHUB_URL=https://github.com/your-username/xiaozhi-note

# Gitee repository URL
VITE_GITEE_URL=https://gitee.com/your-username/xiaozhi-note
